# --- OpenAI (le cerveau du coach) ---
OPENAI_API_KEY=sk-...

# Modèle OpenAI. gpt-4o = bon équilibre qualité/coût. Tu peux mettre gpt-4o-mini
# pour réduire les coûts pendant les tests.
OPENAI_MODEL=gpt-4o

# --- Twilio WhatsApp (Sandbox pour le proto) ---
# Récupère ces valeurs sur https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
# Numéro WhatsApp Sandbox Twilio (par défaut le numéro partagé du sandbox)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Base de données ---
DATABASE_PATH=coach.db
